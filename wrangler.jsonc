{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pages",
  "main": "src/index.mjs",
  "compatibility_date": "2026-06-07",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "inventadors.com",
      "custom_domain": true
    },
    {
      "pattern": "www.inventadors.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  }
}
